{
  "name": "game-save-manager",
  "version": "2.1.0",
  "description": "Easily backup and restore your game saves anytime",
  "main": "dist-ts/main/main.js",
  "scripts": {
    "start": "concurrently -k --success=first \"npm:tailwind:build\" \"npm:electron:start\"",
    "tailwind:build": "tailwindcss -i ./src/renderer/css/style_config.css -o ./src/renderer/css/styles.css --watch",
    "electron:start": "wait-on ./src/renderer/css/styles.css && electron .",
    "pack": "electron-builder --dir --x64",
    "build": "electron-builder --win --x64",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc",
    "prestart": "npm run tsc",
    "prebuild": "npm run tsc"
  },
  "build": {
    "extends": null,
    "icon": "./assets/logo.ico",
    "appId": "com.leafvmaple.game-save-manager",
    "productName": "Game Save Manager",
    "copyright": "Copyright © 2024-2025 Zohar Lee",
    "files": [
      "assets/**/*",
      "locales/**/*",
      "src/renderer/**/*",
      "src/types/**/*",
      "dist-ts/**/*",
      "package.json"
    ],
    "extraFiles": [
      "./database/database.db"
    ],
    "win": {
      "icon": "./assets/logo.ico",
      "target": [
        "nsis",
        "zip"
      ]
    }
  },
  "author": "Yongcan Yang, Zohar Lee",
  "license": "GPL-3.0-only",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "fs-extra": "^11.3.5",
    "glob": "^13.0.6",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-fs-backend": "^2.6.6",
    "js-yaml": "^4.2.0",
    "moment": "^2.30.1",
    "pinyin": "^4.0.0",
    "sqlite3": "^6.0.1",
    "vdf-parser": "^1.2.1",
    "winreg": "^1.2.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/winreg": "^1.2.36",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
